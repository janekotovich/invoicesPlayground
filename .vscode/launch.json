{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug API (.NET)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-api",
      "program": "${workspaceFolder}/Invoices.Api/bin/Debug/net10.0/Invoices.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/Invoices.Api",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5129"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    }
  ]
}
